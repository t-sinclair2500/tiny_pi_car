{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "watcher": {
    "ignore": [
      "**/.venv/**",
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      "**/*.egg-info/**",
      "**/captures/**",
      "**/recordings/**",
      "**/playground/vision/models/**",
      "**/.cache/**",
      "**/.autoresearch/artifacts/**",
      "**/.opencode/node_modules/**"
    ]
  },
  "instructions": [
    "AGENTS.md",
    "autoresearch/car/program.md",
    ".cursor/rules/*.mdc"
  ],
  "agent": {
    "build": {
      "mode": "primary",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "permission": {
        "task": {
          "*": "deny",
          "autoresearch-director": "allow",
          "autoresearch-worker": "allow",
          "autoresearch-helper": "allow",
          "autoresearch-reviewer": "allow",
          "pi-observer": "allow",
          "pi-motion": "allow",
          "verify": "allow",
          "quick": "allow",
          "explore": "allow"
        }
      }
    }
  }
}
